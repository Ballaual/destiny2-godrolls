# Alle Variablen mit VITE_ Prefix — werden sowohl von den Node.js Scripts
# als auch vom Frontend (Vite/Browser) gelesen.
VITE_BUNGIE_API_KEY=your_bungie_api_key_here
VITE_GODROLL_DATABASE_URL=your_godroll_database_url_here
VITE_BUNGIE_CLIENT_ID=your_bungie_oauth_client_id_here
VITE_BUNGIE_TOKEN_PROXY=https://your-worker.your-account.workers.dev

# Nur Backend (Discord Sync)
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here